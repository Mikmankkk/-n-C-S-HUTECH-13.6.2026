# ============================================================
# Hoshizora Suricata Rules  —  Modbus TCP Intrusion Detection
# File: suricata/rules/modbus.rules
#
# Topology:
#   Authorised Master : 192.168.10.10  (HSZR-SCADA)
#   Slave             : 192.168.10.20  (HSZR-IOT, port 502)
#   Rogue Injector    : any other host  (HSZR-MBI)
#
# Modbus TCP framing (offsets from TCP payload start):
#   [0-1]  Transaction ID
#   [2-3]  Protocol ID  (always 0x00 0x00)
#   [4-5]  Length
#   [6]    Unit ID
#   [7]    Function Code  ← primary detection point
#   [8+]   PDU data
# ============================================================

# ── Rule 1: Unauthorised FC06 — Write Single Register ──────────────────────
alert tcp !192.168.10.10 any -> 192.168.10.20 502 (
    msg:"[HOSHIZORA] Unauthorized Modbus FC06 Write Single Register";
    flow:established,to_server;
    content:"|00 00|"; offset:2; depth:2;
    content:"|06|"; offset:7; depth:1;
    classtype:attempted-admin;
    sid:9000001; rev:2;
    metadata:affected_product ICS, attack_target HSZR-IOT;
)

# ── Rule 2: Unauthorised FC16 — Write Multiple Registers ───────────────────
alert tcp !192.168.10.10 any -> 192.168.10.20 502 (
    msg:"[HOSHIZORA] Unauthorized Modbus FC16 Write Multiple Registers";
    flow:established,to_server;
    content:"|00 00|"; offset:2; depth:2;
    content:"|10|"; offset:7; depth:1;
    classtype:attempted-admin;
    sid:9000002; rev:2;
    metadata:affected_product ICS, attack_target HSZR-IOT;
)

# ── Rule 3: Alarm Register Suppression (FC06, reg=3, val=0) ────────────────
# Matches the payload pattern: FC06 | reg 0x0003 | val 0x0000
alert tcp !192.168.10.10 any -> 192.168.10.20 502 (
    msg:"[HOSHIZORA] Modbus Alarm Register Suppression - FC06 ALM=0";
    flow:established,to_server;
    content:"|06 00 03 00 00|"; offset:7; depth:5;
    classtype:attempted-admin;
    sid:9000003; rev:2;
)

# ── Rule 4: Any Modbus write from UNKNOWN host (catch-all) ─────────────────
alert tcp !192.168.10.10 any -> 192.168.10.20 502 (
    msg:"[HOSHIZORA] Modbus Write Attempt from Unauthorized Source";
    flow:established,to_server;
    content:"|00 00|"; offset:2; depth:2;
    byte_test:1,&,0x04,7;
    classtype:policy-violation;
    sid:9000004; rev:1;
)

# ── Rule 5: Sensor value spoof — temperature > 500 (5000 raw = 0x1388) ─────
alert tcp !192.168.10.10 any -> 192.168.10.20 502 (
    msg:"[HOSHIZORA] Modbus Sensor Spoof - Temperature Out of Range";
    flow:established,to_server;
    content:"|06 00 04|"; offset:7; depth:3;
    byte_test:2,>,5000,10,big;
    classtype:attempted-admin;
    sid:9000005; rev:1;
)
